MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/DATABASE_NAME
JWT_SECRET=your_long_random_secret
GEMINI_API_KEY=your_gemini_api_key
PORT=5000

# CORS: your Vercel production URL (comma-separated for multiple)
# Example: https://auto-biz.vercel.app
CLIENT_ORIGIN=https://your-app.vercel.app

# Optional — allow any *.vercel.app (preview deployments). Do not use in untrusted production.
# ALLOW_VERCEL_PREVIEWS=true

# Optional — email
EMAIL_USER=
EMAIL_PASS=
UPI_ID=
